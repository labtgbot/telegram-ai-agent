# Base URL of the Telegram AI Agent backend API (FastAPI).
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Sentry browser SDK. Leave VITE_SENTRY_DSN empty to disable Sentry locally.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0
