# Caddyfile for the production-like docker-compose stack.
#
# Caddy handles ACME (TLS) automatically — point DNS at the host and traffic
# on :80/:443 lands here. Bot webhook + REST + Mini App live on the main
# DOMAIN; the admin dashboard on ADMIN_DOMAIN.
{
	email {$ACME_EMAIL:ops@example.com}
}

{$DOMAIN:bot.example.com} {
	encode zstd gzip

	@api path /api/*
	handle @api {
		reverse_proxy backend:8000
	}

	# Health endpoint — also useful for upstream uptime checks.
	@health path /healthz
	handle @health {
		reverse_proxy backend:8000/api/v1/health/live
	}

	# Mini App static bundle.
	handle {
		reverse_proxy mini-app:80
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format json
	}
}

{$ADMIN_DOMAIN:admin.example.com} {
	encode zstd gzip

	reverse_proxy admin:3001

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format json
	}
}
