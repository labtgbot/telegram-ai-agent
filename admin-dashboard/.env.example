# Public — exposed to the browser.
# Base URL of the backend FastAPI service.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Server-only — used by middleware and route handlers.
# Must match backend ADMIN_JWT_SECRET so the panel can verify access tokens.
ADMIN_JWT_SECRET=change-me
# Algorithm used by backend (HS256 by default).
ADMIN_JWT_ALGORITHM=HS256
# Server-side base URL when running inside docker / behind a reverse proxy.
# Falls back to NEXT_PUBLIC_API_BASE_URL when unset.
API_BASE_URL=

# Sentry — leave the DSN values empty to disable Sentry locally.
# NEXT_PUBLIC_SENTRY_DSN is sent to the browser bundle; SENTRY_DSN is used
# server-side and falls back to NEXT_PUBLIC_SENTRY_DSN when not set.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0
