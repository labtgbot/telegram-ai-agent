# Public — exposed to the browser.
# Base URL of the backend FastAPI service.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Server-only — used by middleware and route handlers.
# Must match backend ADMIN_JWT_SECRET so the panel can verify access tokens.
ADMIN_JWT_SECRET=change-me
# Algorithm used by backend (HS256 by default).
ADMIN_JWT_ALGORITHM=HS256
# Server-side base URL when running inside docker / behind a reverse proxy.
# Falls back to NEXT_PUBLIC_API_BASE_URL when unset.
API_BASE_URL=
