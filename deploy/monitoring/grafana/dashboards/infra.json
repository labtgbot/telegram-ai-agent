          "expr": "histogram_quantile(0.99, sum by (le, handler) (rate(http_request_duration_seconds_bucket{job=~\"telegram-ai-agent.*\"}[5m])))",
          "legendFormat": "p99 {{handler}}",
          "refId": "C"
        }
