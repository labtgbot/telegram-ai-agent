  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum by (method) (rate(http_requests_total{job=~\"telegram-ai-agent.*\"}[5m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "title": "HTTP request rate (per method)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{job=~\"telegram-ai-agent.*\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=~\"telegram-ai-agent.*\"}[5m])), 1)",
          "legendFormat": "5xx ratio",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{job=~\"telegram-ai-agent.*\",status=~\"4..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=~\"telegram-ai-agent.*\"}[5m])), 1)",
          "legendFormat": "4xx ratio",
          "refId": "B"
        }
      ],
      "title": "HTTP error ratio",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 },
