# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MINI_APP_URL=https://localhost:3000
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_SIGNUP_BONUS_TOKENS=50
TELEGRAM_UPDATE_IDEMPOTENCY_TTL_SECONDS=604800
TELEGRAM_SET_COMMANDS_ON_STARTUP=true

# Backend
APP_ENV=development
APP_SECRET=change-me
APP_DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=console
API_V1_PREFIX=/api/v1
HEALTH_CHECK_TIMEOUT=2.0
TRUSTED_PROXY_IPS=

# Production Docker Compose routing / images
DOMAIN=bot.example.com
ADMIN_DOMAIN=admin.example.com
ACME_EMAIL=ops@example.com
CADDY_DATA_DIR=/opt/telegram-ai-agent/caddy/data
CADDY_CONFIG_DIR=/opt/telegram-ai-agent/caddy/config
POSTGRES_PASSWORD=
REDIS_PASSWORD=
BACKEND_IMAGE=ghcr.io/labtgbot/telegram-ai-agent/backend:0.1.0
MINI_APP_IMAGE=ghcr.io/labtgbot/telegram-ai-agent/mini-app:0.1.0
ADMIN_IMAGE=ghcr.io/labtgbot/telegram-ai-agent/admin:0.1.0

# Frontend/API URLs
VITE_API_BASE_URL=http://localhost:8000/api/v1
# Production admin dashboard URLs. For docker/compose.prod.yml, the browser
# URL should point to the public backend ingress and the server URL should use
# the compose service name. Use localhost only in local frontend env files.
NEXT_PUBLIC_API_BASE_URL=https://bot.example.com/api/v1
API_BASE_URL=http://backend:8000/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/telegram_ai_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Composio MCP
COMPOSIO_MODE=mock
COMPOSIO_API_KEY=
COMPOSIO_DEFAULT_USER_ID=
COMPOSIO_BASE_URL=https://backend.composio.dev
COMPOSIO_TIMEOUT_SECONDS=30.0
COMPOSIO_MAX_RETRIES=3
COMPOSIO_BACKOFF_BASE_SECONDS=0.5
COMPOSIO_BACKOFF_MAX_SECONDS=8.0
COMPOSIO_DEFAULT_TOOLKITS=gemini,composio_search,image_gen,video_gen

# AI Providers
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Admin
ADMIN_JWT_SECRET=change-me
ADMIN_JWT_ALGORITHM=HS256
ADMIN_ACCESS_TOKEN_TTL=900
ADMIN_REFRESH_TOKEN_TTL=604800
ADMIN_LOGIN_CODE_TTL=300
ADMIN_LOGIN_CODE_LENGTH=6
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_SUPER_TELEGRAM_IDS=
TOTP_ISSUER=Telegram AI Agent
TELEGRAM_INIT_DATA_MAX_AGE=86400

# Payments
PAYMENT_PROVIDER_TOKEN=
PAYMENT_CURRENCY=XTR

# Monitoring (Prometheus)
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_ACTIVE_USER_WINDOW_SECONDS=300

# Monitoring (Sentry — backend)
# Leave SENTRY_DSN empty to disable Sentry locally.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
