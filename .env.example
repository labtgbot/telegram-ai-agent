# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MINI_APP_URL=https://localhost:3000
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_SIGNUP_BONUS_TOKENS=50
TELEGRAM_SET_COMMANDS_ON_STARTUP=true

# Backend
APP_ENV=development
APP_SECRET=change-me
APP_DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=console
API_V1_PREFIX=/api/v1
HEALTH_CHECK_TIMEOUT=2.0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/telegram_ai_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Composio
COMPOSIO_API_KEY=
COMPOSIO_DEFAULT_USER_ID=

# AI Providers
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Admin
ADMIN_JWT_SECRET=change-me
ADMIN_JWT_ALGORITHM=HS256
ADMIN_ACCESS_TOKEN_TTL=900
ADMIN_REFRESH_TOKEN_TTL=604800
ADMIN_LOGIN_CODE_TTL=300
ADMIN_LOGIN_CODE_LENGTH=6
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_SUPER_TELEGRAM_IDS=
TOTP_ISSUER=Telegram AI Agent
TELEGRAM_INIT_DATA_MAX_AGE=86400

# Payments
PAYMENT_PROVIDER_TOKEN=
PAYMENT_CURRENCY=XTR
